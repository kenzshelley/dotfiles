{
    "window.commandCenter": true,
    "workbench.colorTheme": "Base16 Default Dark",
    "[python]": {
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.defaultColorDecorators": "never"
    },
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },
    "vscode-neovim.logOutputToConsole": true,
    "vscode-neovim.neovimInitVimPaths.darwin": "/Users/mackenzie/programming/dotfiles/config/nvim/init.lua",
    "vscode-neovim.logLevel": "debug",
    "vscode-neovim.trace.server": "verbose",
    "vscode-neovim.ctrlKeysForInsertMode": [
        "a",
        "c",
        "d",
        "m",
        "o",
        "r",
        "t",
        "u",
        "w"
    ],
    "vscode-neovim.ctrlKeysForNormalMode": [
        "a",
        "b",
        "c",
        "d",
        "e",
        "f",
        "i",
        "m",
        "o",
        "r",
        "t",
        "u",
        "v",
        "w",
        "x",
        "y",
        "z",
        "/",
        "]",
        "right",
        "left",
        "up",
        "down",
        "backspace",
        "delete"
    ],
    "base16.generator.activatedThemes": [
        "base16-material-vivid-dark"
    ],
    "files.autoSave": "afterDelay",
    "window.autoDetectColorScheme": true,
    "python.languageServer": "None",
    "cursorpyright.shouldImportPylanceSettings": "never",
    "cursorpyright.analysis.extraPaths": [
        "./python"
    ],
    "cursorpyright.analysis.autoSearchPaths": true,
    "cursorpyright.analysis.useLibraryCodeForTypes": true,
    "git.blame.editorDecoration.enabled": true,
    "claudeCode.preferredLocation": "panel",
    "git.enableSmartCommit": true,
    "terminal.external.osxExec": "Ghostty.app",
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.fontFamily": "MesloLGS NF, Menlo, Monaco, monospace"
}